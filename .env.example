# ===== Backend (NestJS) env =====
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=urlshortener

# JWT
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Redis (cache-aside cho redirect). Local: docker-compose.dev.yml dựng sẵn.
# Render: dùng Internal Key Value URL. Để trống cũng chạy (mặc định localhost).
REDIS_URL=redis://localhost:6379

# Base URL dùng để build link rút gọn (vd: https://sho.rt)
SHORT_BASE_URL=http://localhost:3001

# Frontend URL (để redirect sau khi đăng nhập Google)
FRONTEND_URL=http://localhost:3000

# Google OAuth (lấy từ Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Facebook OAuth (lấy từ Meta for Developers)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/auth/facebook/callback
